# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/skillbridge?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_STRONG_RANDOM_SECRET_HERE
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_STRONG_SECRET_HERE
JWT_REFRESH_EXPIRES_IN=30d

# Email (Gmail App Password — NOT your real Gmail password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=SkillBridge <noreply@skillbridge.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Gemini AI
GEMINI_API_KEY=your_gemini_key

# Google Maps
GOOGLE_MAPS_API_KEY=your_maps_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
